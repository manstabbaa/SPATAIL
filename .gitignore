# ─── OS / editor ───────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─── Python ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/

# ─── Node ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*

# ─── Blender (heavy binaries; rebuild from .obj via
#     skills, or ship via git-lfs / external bucket) ─
*.blend
*.blend1
*.blend2
*.blend@

# Per-asset OBJ inputs are mostly kept (source of truth) — except files
# exceeding GitHub's 100MB hard limit. Use git-lfs or external storage
# (Dropbox / S3) for the big ones; here we exclude them by name so the
# repo stays push-able.
!assets_raw/**/*.obj
assets_raw/f1-car/TOBi_Racing.obj

# ─── Bundle staging (interim dirs from spatail_export_xr) ─
bundles/*.stage/
*.spatail.stage/

# ─── Xcode ─────────────────────────────────────────
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
build/
DerivedData/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
.swiftpm/

# Generated by `xcodegen generate`
SPATAILMobileAR/*.xcodeproj/
ios/**/*.xcodeproj/

# Local-only Xcode app target wrapping the SwiftPM library
ios/SpatailPlayer-App/

# Swift Package Manager local state
.build/
Package.resolved

# ─── SPATAIL artifacts ─────────────────────────────
# Treatment study JSONs are computed; usually small,
# tracked when useful. Strip clearly-volatile caches.
# 4.7GB of segmented meshes — regenerable from skills
assets_processed/
docs/screenshots/_tmp/
# built web viewer artifacts
dist/

# Claude / agent local state
.claude/projects/
.claude/state/

# ─── OS-specific runtime junk ──────────────────────
*.log
*.tmp

# ─── Files exceeding GitHub's 100MB hard limit (use LFS/external if needed) ─
engineexplainer/engine/v8_engine.glb
renders/kitchen_xr_risotto_step5.glb
